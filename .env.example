# .env.example — copy to `.env` and fill in your keys
OPENAI_API_KEY=your-openai-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here
GOOGLE_API_KEY=your-google-api-key-here
OPENROUTER_API_KEY=your-openrouter-key-here

# Startup mode — set to skip the interactive dialog on container launch.
# Options: web (Web-UI + API), cli (interactive terminal), tui (TUI dashboard).
# Leave blank for the interactive dialog.
# MAESTRO_MODE=

# Auto-updater — background polling for git updates.
# Set to 1 to enable periodic update checks.
# MAESTRO_AUTO_UPDATE=0

# Poll interval in seconds (default: 60, minimum: 10).
# MAESTRO_UPDATE_INTERVAL=60

# Automatically apply updates without user interaction.
# Great for iterative development where you push fixes and want them
# picked up immediately.
# MAESTRO_AUTO_APPLY_UPDATES=0

# Override the remote repository URL (for forks).
# MAESTRO_UPDATE_REMOTE=

# Override the branch to track (default: current branch or "main").
# MAESTRO_UPDATE_BRANCH=
