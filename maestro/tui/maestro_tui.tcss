/*
 * Maestro TUI — Textual CSS
 *
 * Optimized for 80x24 minimum terminal on Raspberry Pi 5.
 * Scales responsively to larger terminals.
 * Polished for video-demo aesthetics.
 */

/* ── Global ───────────────────────────────────────────────────── */

Screen {
    layout: vertical;
    background: $background;
}

Header {
    dock: top;
    height: 1;
}

/* ── Top row: agent panel + consensus panel ───────────────────── */

#top-row {
    height: auto;
    max-height: 10;
    min-height: 8;
}

#agent-panel {
    width: 1fr;
    min-width: 36;
    max-width: 42;
}

#agent-panel-title {
    text-style: bold;
    color: $primary;
}

#consensus-panel {
    width: 2fr;
    min-width: 40;
}

#consensus-panel-title {
    text-style: bold;
    color: $primary;
}

/* ── Response viewer (main content area) ──────────────────────── */

#response-viewer {
    height: 1fr;
    min-height: 6;
}

#response-log {
    scrollbar-size: 1 1;
    padding: 0 1;
}

/* ── Cluster dashboard (live instance monitor) ──────────────── */

#cluster-dashboard {
    height: auto;
    max-height: 12;
    min-height: 3;
}

#cluster-dash-title {
    text-style: bold;
    color: $primary;
}

/* ── LAN Discovery panel ─────────────────────────────────────── */

#discovery-panel {
    height: auto;
    max-height: 10;
    min-height: 4;
}

#discovery-panel-title {
    text-style: bold;
    color: $primary;
}

/* ── Shard network panel ──────────────────────────────────────── */

#shard-panel {
    height: auto;
    max-height: 8;
    min-height: 3;
}

#shard-panel-title {
    text-style: bold;
    color: $primary;
}

/* ── Prompt hint (minimized — press P for full Prompt screen) ── */

#prompt-hint {
    dock: bottom;
    height: 1;
    background: $primary-background;
    color: $text;
    padding: 0 1;
}

/* ── Status bar ───────────────────────────────────────────────── */

StatusBar {
    dock: bottom;
    height: 1;
    background: $primary-background;
    padding: 0 1;
}
