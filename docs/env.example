# Maestro-Orchestrator Environment Example
# Copy this file to `.env` and replace the placeholder values with real API keys

OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_API_KEY=AIzaSyD-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Startup mode — set to skip the interactive dialog on container launch.
# Options: web (Web-UI + API), cli (interactive terminal). Leave blank for dialog.
# MAESTRO_MODE=
