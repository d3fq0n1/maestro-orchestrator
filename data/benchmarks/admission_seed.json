{
  "name": "admission-seed-v1",
  "description": "Hand-crafted seed dataset for Router admission quality. Twelve examples in the data-feasible cluster (topic match, tag prefix, distance variation, trust variation, threshold sensitivity, cross-tier collisions). Cases requiring infrastructure that is still scaffolded (revocation, supersession, phantom hashes, domain-tag squatting, adversarial provenance, corroboration flooding) are deferred to a future integrated-runner track.",
  "examples": [
    {
      "example_id": "topic-match-cartridge",
      "notes": "Topic match: query and cartridge share content + tags; high-trust cartridge should admit.",
      "query": {
        "text": "tax law about deductions",
        "tags": ["law.us"]
      },
      "candidates": [
        {
          "id": "CART:tax-code@2024",
          "text": "tax law about jurisdiction",
          "tier": "cartridge",
          "expected_admit": true,
          "trust": 0.95,
          "tags": ["law.us.federal"]
        },
        {
          "id": "CART:cooking@2024",
          "text": "cooking recipes for garlic",
          "tier": "cartridge",
          "expected_admit": false,
          "trust": 0.95,
          "tags": ["food.recipe"]
        }
      ],
      "ranked_admit": ["CART:tax-code@2024"]
    },
    {
      "example_id": "tag-prefix-match",
      "notes": "Dotted tag prefix: candidate tagged law.us.federal should match query tagged law.us.federal.tax.",
      "query": {
        "text": "tax law about deductions",
        "tags": ["law.us.federal.tax"]
      },
      "candidates": [
        {
          "id": "CART:tax-prefix@1",
          "text": "tax law jurisdiction",
          "tier": "cartridge",
          "expected_admit": true,
          "trust": 0.9,
          "tags": ["law.us.federal"]
        },
        {
          "id": "CART:state-rule@1",
          "text": "tax law jurisdiction",
          "tier": "cartridge",
          "expected_admit": false,
          "trust": 0.9,
          "tags": ["law.ca.state"]
        }
      ]
    },
    {
      "example_id": "trust-determines-cartridge-admission",
      "notes": "Same on-topic content, two cartridges; high-trust admits, low-trust below tau rejects.",
      "query": {
        "text": "constitutional law about speech",
        "tags": ["law.us"]
      },
      "candidates": [
        {
          "id": "CART:trusted@1",
          "text": "constitutional law about expression",
          "tier": "cartridge",
          "expected_admit": true,
          "trust": 0.95,
          "tags": ["law.us"]
        },
        {
          "id": "CART:lowtrust@1",
          "text": "constitutional law about expression",
          "tier": "cartridge",
          "expected_admit": false,
          "trust": 0.20,
          "tags": ["law.us"]
        }
      ]
    },
    {
      "example_id": "cross-tier-cartridge-vs-whirlpool",
      "notes": "Same topic; cartridge admits at high trust, whirlpool admits at moderate trust under lower tau.",
      "query": {
        "text": "law tax breaking",
        "tags": ["law.us"]
      },
      "candidates": [
        {
          "id": "CART:law-spec@1",
          "text": "law tax statute",
          "tier": "cartridge",
          "expected_admit": true,
          "trust": 0.9,
          "tags": ["law.us"]
        },
        {
          "id": "WP:law-feed:abcd1234",
          "text": "law tax breaking news",
          "tier": "whirlpool",
          "expected_admit": true,
          "trust": 0.55,
          "tags": ["law.us"]
        }
      ],
      "ranked_admit": ["CART:law-spec@1", "WP:law-feed:abcd1234"]
    },
    {
      "example_id": "off-topic-whirlpool-rejected",
      "notes": "Whirlpool item with high local trust but completely off-topic relative to query.",
      "query": {
        "text": "law tax",
